{
  "AllowedHosts": "*",
  "ApplicationSettings": {
    "AnthropicApiKey": "your-anthropic-api-key-here",
    "CodebaseMappings": {
      "MyCodeBase": "D:\\path\\to\\my-codebase",
      "AnotherProject": "D:\\path\\to\\another-project"
    },
    "GitHubRepositories": {
      "MyCodeBase": {
        "Owner": "your-username",
        "Name": "my-codebase-repo"
      },
      "AnotherProject": {
        "Owner": "your-username",
        "Name": "another-project-repo"
      }
    },
    "ExecutionIntervalInSeconds": 3600, //One hour.
    "GitHubToken": "your-github-token-here",
    "MaxRetryDelayInSeconds": 300,
    "TrelloApiKey": "your-trello-api-key-here",
    "TrelloApiToken": "your-trello-api-token-here",
    "TrelloBoardIds": ["array-of-trello-board-ids"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}